planning/

# Astro build artifacts (generated on each build by build:content)
src/content/lessons/
public/lesson-assets/
.astro/
dist/

# NOTE: src/content/resources/ and src/data/zotero.json are NOT gitignored —
# they're generated by `npm run build:resources` but committed manually so
# Cloudflare can serve them without needing API tokens at build time.

